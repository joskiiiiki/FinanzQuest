{$CADDY_HOST:finanzquest.app} {
	# 10MB upload limit
	request_body {
		max_size 10MB
	}

	handle /auth/v1/* {
		uri strip_prefix /auth/v1

		@options method OPTIONS
		handle @options {
			header Access-Control-Allow-Origin *
			header Access-Control-Allow-Methods "GET,HEAD,PUT,PATCH,POST,DELETE,OPTIONS,TRACE,CONNECT"
			header Access-Control-Allow-Headers "Authorization,apikey,Content-Type,X-Client-Info,x-supabase-api-version"
			header Access-Control-Max-Age 3600
			respond "" 204
		}

		handle {
			reverse_proxy auth:9999 {
				header_down Access-Control-Allow-Origin *
				header_down Access-Control-Allow-Methods "GET,HEAD,PUT,PATCH,POST,DELETE,OPTIONS,TRACE,CONNECT"
				header_down Access-Control-Allow-Headers "Authorization,apikey,Content-Type,X-Client-Info,x-supabase-api-version"
			}
		}
	}
	handle /rest/v1/* {
		uri strip_prefix /rest/v1
		reverse_proxy rest:3000
	}

	# Frontend (catch-all)
	handle {
		reverse_proxy frontend:3000 {
			fail_duration 5s
		}
	}
}

